# AWS (uses default credential chain for Bedrock CloudWatch access)
AWS_REGION=us-east-1

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Anthropic (Admin API key for org-level usage) - Phase 2
ANTHROPIC_ADMIN_API_KEY=sk-ant-admin-...
ANTHROPIC_ORG_ID=org-...

# OpenAI (Admin API key for org-level usage) - Phase 2
OPENAI_ADMIN_API_KEY=sk-admin-...
OPENAI_ORG_ID=org-...

# Bedrock Invocation Log Analysis (optional)
BEDROCK_LOG_BUCKET=your-bedrock-log-bucket
BEDROCK_LOG_PREFIX=AWSLogs
